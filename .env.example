# Copy to runtime/llm.env. Never commit the copied file.
REHAB_LLM_PROVIDER=auto
REHAB_LLM_ONLINE_PROVIDER=glm4v_api
REHAB_LLM_OFFLINE_PROVIDER=local_qwen_rkllm

# Optional online GLM
GLM_API_KEY=
REHAB_LLM_MODEL=glm-4v-flash

# Optional local Qwen RKLLM
QWEN_RKLLM_MODEL=models/language/qwen/qwen1_5b.rkllm
QWEN_SERVER_DIR=/home/elf/qwen_server/rkllm_server

# Optional local speech models
REHAB_ASR_MODEL_DIR=models/audio/asr/paraformer
REHAB_TTS_MODEL_DIR=models/audio/tts/sherpa_vits

# Board peripherals
RK_CAMERA_DEVICE=/dev/v4l/by-id/usb-icSpring_icspring_camera-video-index0
REHAB_AUDIO_OUTPUT_DEVICE=plughw:1,0
